#!/usr/bin/env bash
set -euo pipefail

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "${repo_root}"

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"
if [[ -z "${staged_files}" ]]; then
  exit 0
fi

violations=()

while IFS= read -r file; do
  [[ -z "${file}" ]] && continue

  case "${file}" in
    .env|.env.*)
      if [[ "${file}" != ".env.example" ]]; then
        violations+=("Blocked staged file: ${file} (keep local env files out of git).")
      fi
      ;;
  esac

  patch="$(git diff --cached -U0 -- "${file}" || true)"

  added_api_lines="$(
    printf '%s\n' "${patch}" \
      | grep -E '^\+[^+].*((ARMANDO_(OPENAI|GEMINI|ANTHROPIC)_API_KEY|(OPENAI|GEMINI|ANTHROPIC)_API_KEY)[[:space:]]*=[[:space:]]*[^[:space:]]+|api_key[[:space:]]*:[[:space:]]*["'\'']?(sk-[A-Za-z0-9_-]{20,}|sk-ant-[A-Za-z0-9_-]{20,}|AIza[0-9A-Za-z_-]{20,}|[A-Za-z0-9_-]{24,}))' \
      | grep -Ev 'YOUR_(OPENAI|GEMINI|ANTHROPIC)_API_KEY' \
      || true
  )"
  if [[ -n "${added_api_lines}" ]]; then
    violations+=("Possible API key in ${file}: ${added_api_lines}")
  fi

  token_matches="$(
    printf '%s\n' "${patch}" \
      | grep -E '^\+[^+].*(sk-[A-Za-z0-9_-]{20,}|sk-ant-[A-Za-z0-9_-]{20,}|AIza[0-9A-Za-z_-]{20,})' \
      || true
  )"
  if [[ -n "${token_matches}" ]]; then
    violations+=("Possible secret token in ${file}: ${token_matches}")
  fi
done <<< "${staged_files}"

if [[ "${#violations[@]}" -gt 0 ]]; then
  {
    echo "pre-commit: secret check failed."
    echo
    for item in "${violations[@]}"; do
      echo "- ${item}"
    done
    echo
    echo "Use placeholders (YOUR_*), env vars, or remove the secret from staged changes."
  } >&2
  exit 1
fi

exit 0

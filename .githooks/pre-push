#!/usr/bin/env bash
set -euo pipefail

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "${repo_root}"

# Git passes push updates on stdin: <local-ref> <local-oid> <remote-ref> <remote-oid>
# We run the regression gate whenever at least one non-delete update is present.
run_gate=0
while read -r local_ref local_oid remote_ref remote_oid; do
  [[ -z "${local_ref}" ]] && continue
  if [[ "${local_oid}" != "0000000000000000000000000000000000000000" ]]; then
    run_gate=1
    break
  fi
done

if [[ "${run_gate}" -eq 0 ]]; then
  exit 0
fi

bash scripts/ci/pre-push-regression.sh

